AI_API_KEY=填你的 DeepSeek API Key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash

# DeepSeek 可选项：disabled 更快更省；enabled 会启用思考模式。
AI_THINKING=disabled
AI_REASONING_EFFORT=high

# 可选：机器人人设和语气。
BOT_PERSONA=温暖、机灵、靠谱，有一点轻松的幽默感，但不过度卖萌。像群里认真听大家说话的朋友，回答自然、有分寸、愿意把事情讲清楚。
BOT_TONE=中文口语化，简洁但不冷冰冰；可以适度使用“我来”“可以这样”“先帮你捋一下”这类自然表达。
BOT_EMOJI_STYLE=可以少量使用微信表情码来显得更自然，比如 /强 表示大拇指，/抱拳 表示感谢或客气，/呲牙 表示轻松一笑。每条回复最多用 0-2 个，不要连续刷屏，也不要在严肃或隐私内容里使用。

# 可选：联网搜索。填 Tavily API Key 后，@机器人 联网搜索 会搜索网页。
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# 可选安全项：默认会脱敏 API Key、token、密码等；默认不按同名群迁移历史，避免同名群串数据。
REDACT_SENSITIVE_DATA=true
ENABLE_ROOM_NAME_HISTORY_MIGRATION=false

# 可选：只响应这些群名，多个群用英文逗号分隔；留空则响应所有群。
ALLOW_ROOMS=

# 可选：每个群最多缓存多少条文字消息。
MAX_MESSAGES_PER_ROOM=500

# 可选：普通聊天时带给模型的最近群聊条数。
CHAT_CONTEXT_MESSAGES=30

# 可选：历史消息保存位置。重启后会从这里恢复缓存。
MESSAGE_STORE_PATH=data/messages.json

# 可选：Wechaty puppet 配置。普通微信能否扫码成功取决于账号和协议可用性。
# WECHATY_PUPPET=wechaty-puppet-wechat4u
# WECHATY_PUPPET=wechaty-puppet-service
# WECHATY_PUPPET_SERVICE_TOKEN=填你的 puppet service token
